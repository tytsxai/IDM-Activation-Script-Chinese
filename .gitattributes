# Keep batch scripts runnable on Windows (IAS.cmd expects CRLF)
*.cmd text eol=crlf

# Keep plain-text helpers aligned with Windows editors
*.txt text eol=crlf

# Normalize Markdown for GitHub
*.md text eol=lf

# GitHub Actions / Issue templates (YAML must be LF)
*.yml text eol=lf
*.yaml text eol=lf
